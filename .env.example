# BTC 5m 邮件盈亏：默认按 Gamma 已结算价（resolution）汇总，主数字与 REDEEM 到账无关
# PNL_PREFER_SETTLEMENT_FINAL=1  # 默认；设为 0 则主口径回到链上 Activity（含 redeem）
# PNL_MAX_SETTLEMENT_SLUGS=3000  # 每封邮件最多对多少个 slug 拉 Gamma；长跑累计勿过小