[Unit]
Description=Advisory v2 intent ↔ fill linking worker (oneshot)
After=postgresql.service network-online.target

[Service]
Type=oneshot
WorkingDirectory=/root/auto_polymarket
EnvironmentFile=-/root/auto_polymarket/.env
Environment=LD_PRELOAD=
ExecStart=/usr/bin/env uv run python scripts/advisory_intent_filler.py
StandardOutput=journal
StandardError=journal
