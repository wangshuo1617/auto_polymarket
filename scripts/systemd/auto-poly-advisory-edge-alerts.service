[Unit]
Description=Auto Polymarket - Advisory Edge-Flip Alerts (business notification)
After=auto-poly-advisory-batch.service

[Service]
Type=oneshot
WorkingDirectory=/root/auto_polymarket
EnvironmentFile=-/root/auto_polymarket/.env
Environment=LD_PRELOAD=
ExecStart=/usr/bin/env uv run scripts/advisory_edge_alerts.py
SuccessExitStatus=0
