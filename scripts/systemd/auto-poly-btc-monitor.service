[Unit]
Description=Auto Polymarket - BTC 1s Market Monitor
After=network-online.target
Wants=network-online.target

StartLimitIntervalSec=300
StartLimitBurst=5
[Service]
Type=exec
WorkingDirectory=/root/auto_polymarket
Environment=FOREGROUND=1
ExecStart=/bin/bash scripts/restart_btc_1s_market_monitor.sh
Restart=on-failure
RestartSec=60
KillMode=mixed
KillSignal=SIGTERM
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
