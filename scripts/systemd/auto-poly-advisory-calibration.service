[Unit]
Description=Auto Polymarket - Advisory Calibration Replay (P3, persisted)
After=auto-poly-advisory-batch.service

[Service]
Type=oneshot
WorkingDirectory=/root/auto_polymarket
EnvironmentFile=-/root/auto_polymarket/.env
Environment=LD_PRELOAD=
ExecStart=/usr/bin/env uv run scripts/advisory_calibration_replay.py --persist --json
SuccessExitStatus=0
